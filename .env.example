# ============================================================
# EC Wound Charting — Environment Variables Template
# ============================================================
# 1. In cPanel File Manager, create a NEW file named exactly: .env
# 2. Copy the keys below and fill in your real values
# 3. NEVER commit .env to Git — it is gitignored
# ============================================================

# --- Database (cPanel → MySQL Databases) ---
# NOTE: On cPanel, DB_USER and DB_NAME are prefixed with your cPanel username
# Example: if cPanel username is "ecwound1", user = "ecwound1_root", db = "ecwound1_ecwound"
DB_HOST=localhost
DB_USER=ecwound1_DBUSER
DB_PASS=YOUR_DB_PASSWORD_HERE
DB_NAME=ecwound1_DBNAME

# --- Google AI (Vertex AI / Gemini) ---
# Get from: console.cloud.google.com/apis/credentials
GEMINI_API_KEY=YOUR_NEW_GEMINI_KEY_HERE

# --- Google Maps ---
# Get from: console.cloud.google.com/apis/credentials
GOOGLE_MAPS_API_KEY=YOUR_NEW_MAPS_KEY_HERE

# --- App Settings ---
APP_TIMEZONE=UTC
